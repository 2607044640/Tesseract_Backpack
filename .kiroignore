# =========================================================
# AI Context Filter - Godot Project (3d-practice)
# Purpose: Exclude noise files from AI context while keeping Git tracking intact
# =========================================================

# Godot engine cache and imports (CRITICAL - these cause indexing to hang)
.godot/
*.import

# Version control
.git/

# Build outputs
build/
bin/
obj/

# IDE files
.idea/
*.csproj.user
*.sln.DotSettings.user

# Backup folders
.backup_old_components/

# NVIDIA cache
NVIDIA Corporation/

# =========================================================
# AI-Specific Noise Reduction (Added per Gemini analysis)
# =========================================================

# 1. Godot UID files (Git needs them, AI doesn't)
*.uid

# 2. Media files AI cannot parse
*.svg
*.gif
*.unitypackage

# 3. Third-party addon source code (too large, AI already knows their APIs)
addons/alignment-tool/
addons/asset_placer/
addons/godot-jolt/
addons/godot-rapier2d/
addons/godot_state_charts/
addons/mixamo_animation_retargeter/
addons/modular-settings-menu/
addons/phantom_camera/
addons/Todo_Manager/
addons/theme_gen/
addons/theme_gen_save_sync/

# 4. Plugin example directories (tutorials, not project code)
godot_state_charts_examples/
addons/phantom_camera/examples/

# 5. Native binaries (C/C++ compiled artifacts)
*.so
*.dll
*.dylib
*.framework/
*.xcframework/
*.a

# 6. Optional: Uncomment to exclude scenes/resources when focusing on C# architecture
# *.tscn
# *.tres
